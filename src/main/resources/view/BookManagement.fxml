<?xml version="1.0" encoding="UTF-8"?>

<?import com.jfoenix.controls.JFXButton?>
<?import com.jfoenix.controls.JFXComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.shape.Rectangle?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="600.0" prefWidth="700.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.BookManagementFormController">
   <children>
      <Rectangle arcHeight="5.0" arcWidth="5.0" fill="#cf9fff" height="70.0" layoutY="-1.0" stroke="#cf9fff" strokeType="INSIDE" width="700.0" />
      <Rectangle arcHeight="5.0" arcWidth="5.0" fill="#fffcfb" height="530.0" layoutY="68.0" stroke="#fffcfb" strokeType="INSIDE" width="700.0" />
      <Label layoutX="168.0" layoutY="10.0" text="Book Management Form">
         <font><Font name="System Bold" size="32.0" /></font>
      </Label>
      <TextField fx:id="txtbookID" alignment="CENTER" layoutX="36.0" layoutY="102.0" promptText="BookID" />
      <TextField fx:id="txtISBN" alignment="CENTER" layoutX="275.0" layoutY="102.0" promptText="ISBN" />
      <TextField fx:id="txtTitel" alignment="CENTER" layoutX="512.0" layoutY="102.0" promptText="Title" />
      <TextField fx:id="txtAuthor" alignment="CENTER" layoutX="36.0" layoutY="155.0" promptText="Author" />
      <TextField fx:id="txtGenre" alignment="CENTER" layoutX="275.0" layoutY="155.0" promptText="Genre" />
      <JFXComboBox fx:id="txtAvailability" layoutX="512.0" layoutY="155.0" prefHeight="26.0" prefWidth="150.0" promptText="Availability" />
      <TextField fx:id="txtSearch" alignment="CENTER" layoutX="36.0" layoutY="208.0" prefWidth="200.0" promptText="Search by Title/Author/Genre" />
      <JFXButton layoutX="255.0" layoutY="208.0" onAction="#btnAddOnAction" prefHeight="30.0" prefWidth="70.0" text="Add">
         <font><Font name="System Bold" size="13.0" /></font>
      </JFXButton>
      <JFXButton layoutX="340.0" layoutY="208.0" onAction="#btnUpdateOnAction" prefHeight="30.0" prefWidth="70.0" text="Update">
         <font><Font name="System Bold" size="13.0" /></font>
      </JFXButton>
      <JFXButton layoutX="425.0" layoutY="208.0" onAction="#btnDeleteOnAction" prefHeight="30.0" prefWidth="70.0" text="Delete">
         <font><Font name="System Bold" size="13.0" /></font>
      </JFXButton>
      <JFXButton layoutX="510.0" layoutY="208.0" onAction="#btnSearchOnAction" prefHeight="30.0" prefWidth="70.0" text="Search">
         <font><Font name="System Bold" size="13.0" /></font>
      </JFXButton>
      <JFXButton layoutX="600.0" layoutY="208.0" onAction="#btnReloadOnAction" prefHeight="30.0" prefWidth="70.0" text="Reload">
         <font><Font name="System Bold" size="13.0" /></font>
      </JFXButton>
      <TableView fx:id="tblBookTable" fixedCellSize="0.0" layoutX="7.0" layoutY="250.0" prefHeight="291.0" prefWidth="686.0" stylesheets="@../css/tablecss.css">
        <columns>
          <TableColumn fx:id="colbookID" prefWidth="80.0" text="BookID" />
          <TableColumn fx:id="colISBN" prefWidth="120.0" text="ISBN" />
          <TableColumn fx:id="colTitel" prefWidth="120.0" text="Title" />
          <TableColumn fx:id="colAuthor" prefWidth="130.0" text="Author" />
          <TableColumn fx:id="colGenre" prefWidth="100.0" text="Genre" />
          <TableColumn fx:id="colAvailability" prefWidth="136.0" text="Availability" />
        </columns>
      </TableView>
   </children>
</AnchorPane>
